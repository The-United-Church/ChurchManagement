rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isConversationParticipant(data) {
      return signedIn()
        && data.participantIds is list
        && request.auth.uid in data.participantIds;
    }

    function validParticipantList(data) {
      return data.participantIds is list
        && data.participantIds.size() == 2
        && request.auth.uid in data.participantIds;
    }

    function validConversationCreate(data) {
      return signedIn()
        && data.keys().hasOnly([
          'participantIds',
          'participants',
          'lastMessage',
          'lastMessageAt',
          'lastSenderId',
          'unread'
        ])
        && validParticipantList(data)
        && data.participants is map
        && data.unread is map
        && data.lastMessage is string
        && data.lastMessage.size() <= 280
        && (data.lastMessageAt == null || data.lastMessageAt is timestamp)
        && data.lastSenderId is string;
    }

    function validConversationUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isConversationParticipant(resource.data)
        && isConversationParticipant(request.resource.data)
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.participants == resource.data.participants
        && changed.hasOnly(['lastMessage', 'lastMessageAt', 'lastSenderId', 'unread'])
        && (!changed.hasAny(['lastMessage'])
          || (request.resource.data.lastMessage is string
            && request.resource.data.lastMessage.size() <= 280))
        && (!changed.hasAny(['lastMessageAt'])
          || request.resource.data.lastMessageAt is timestamp)
        && (!changed.hasAny(['lastSenderId'])
          || request.resource.data.lastSenderId == request.auth.uid)
        && request.resource.data.unread is map;
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(resource.data);
      allow create: if validConversationCreate(request.resource.data);
      allow update: if validConversationUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        function parentConversation() {
          return get(/databases/$(database)/documents/conversations/$(conversationId));
        }

        function isParentConversationParticipant() {
          return signedIn()
            && request.auth.uid in parentConversation().data.participantIds;
        }

        function validMessageCreate(data) {
          return isParentConversationParticipant()
            && data.keys().hasOnly(['conversationId', 'senderId', 'text', 'createdAt'])
            && data.conversationId == conversationId
            && data.senderId == request.auth.uid
            && data.text is string
            && data.text.size() > 0
            && data.text.size() <= 4000
            && data.createdAt == request.time;
        }

        allow read: if isParentConversationParticipant();
        allow create: if validMessageCreate(request.resource.data);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}